# ---- MongoDB Atlas -----------------------------------------------
# 1) 去 https://www.mongodb.com/atlas 注册（免费）
# 2) 创建一个 M0 Free 集群
# 3) 添加数据库用户（记住用户名和密码）
# 4) 在 Network Access 里添加 0.0.0.0/0（允许所有 IP，或只加 Render 的 IP）
# 5) 点 Connect → Drivers → 复制连接字符串，粘贴到下面
#    记得把 <password> 替换成你的真实密码，把 <dbname> 替换成 ruyibao
MONGODB_URI=mongodb+srv://用户名:密码@cluster0.xxxxx.mongodb.net/ruyibao?retryWrites=true&w=majority

# ---- GLM (Zhipu AI) configuration -----------------------------------
# 去 https://open.bigmodel.cn/ 注册并创建一个 API Key
LLM_API_KEY=
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_MODEL=glm-4-flash

# ---- Server ---------------------------------------------------------
PORT=3000
